# ===== Database =====
# Azure SQL connection string (local dev can point to a local SQL Server / Docker instance)
ConnectionStrings__DefaultConnection=Server=localhost;Database=WhyNoPower;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=True

# ===== Auth =====
# Symmetric signing key for JWT - generate a long random string, never reuse across environments
Jwt__Key=REPLACE_WITH_A_LONG_RANDOM_SECRET
Jwt__Issuer=WhyNoPower
Jwt__Audience=WhyNoPower

# ===== Solar / Weather APIs (Phase 1) =====
# Open-Meteo requires no key
Solcast__ApiKey=REPLACE_WITH_SOLCAST_KEY

# ===== Growatt ShinePhone (Phase 1 - actuals ingestion) =====
Growatt__Username=REPLACE_WITH_SHINEPHONE_USERNAME
Growatt__Password=REPLACE_WITH_SHINEPHONE_PASSWORD

# ===== ASP.NET Core =====
ASPNETCORE_ENVIRONMENT=Development

# Phase 2 (EskomSePush) and Phase 3 (Johannesburg Water) keys will be added
# here as their ADRs/PRs land - see docs/adr/
